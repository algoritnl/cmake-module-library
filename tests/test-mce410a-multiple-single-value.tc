cmut_generate_cb() {
    cat -- <<EOF
cmake_minimum_required(VERSION 3.16...4.3)
project(${1} LANGUAGES NONE)

set(CMAKE_MESSAGE_LOG_LEVEL TRACE)
set(CMAKE_MESSAGE_CONTEXT_SHOW TRUE)

include("${2}/MultipleChoice.cmake")

set(COLOR red green CACHE STRING "")
multiple_choice(
    COLOR
    VALID_VALUES red green blue
    FATAL_ERROR
)
EOF
}

cmut_assert_cb() {
    cmut_assert_run_failed &&
    cmut_assert_stdout_contains "[MCT410a:COLOR]" &&
    cmut_assert_stderr_contains "[MCE430a:COLOR]"
}
